# Variables de Entorno - IICA Chile MVP

# Base de Datos (PostgreSQL / SQLite)
DATABASE_URL=sqlite:///iica_chile.db

# Flask / Next.js Secret
SECRET_KEY=cambia-esta-clave-secreta-en-produccion

# Google Gemini AI (Vercel AI SDK)
# Obtener API key en: https://aistudio.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY=tu-api-key-aqui

# Legacy (si se usa en scripts python antiguos)
GEMINI_API_KEY=tu-api-key-aqui

# Configuracin Generales
NEXT_PUBLIC_API_URL=http://localhost:3000
