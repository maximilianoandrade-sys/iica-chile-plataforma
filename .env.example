# Variables de Entorno - IICA Chile Plataforma

# Base de Datos PostgreSQL
DATABASE_URL=postgresql://user:password@host:5432/database
DIRECT_URL=postgresql://user:password@host:5432/database

# Seguridad admin
ADMIN_PASSWORD=define-una-clave-admin-segura
ADMIN_SESSION_SECRET=genera-una-clave-segura-con-openssl-rand-hex-32

# Seguridad cron
CRON_SECRET=genera-otro-secreto-para-cron

# API Google Gemini (opcional pero requerida para discovery/embeddings)
GEMINI_API_KEY=tu-api-key-aqui

# Mercado Público (opcional)
MERCADO_PUBLICO_TICKET=tu-ticket-aqui

# Alertas/operación (opcionales)
ADMIN_EMAIL=admin@iica.cl
NOTIFICATION_WEBHOOK=https://hooks.slack.com/services/...
DEPLOYMENT_URL=https://iica-chile-plataforma.vercel.app

# Búsqueda externa (opcionales)
SEARCH_EXTERNAL_ENABLED=true
SEARCH_SOURCE_MODE_DEFAULT=internal
SEARCH_EXTERNAL_DISABLED_PROVIDERS=

# Logging (opcional)
LOG_LEVEL=info

# Google Analytics 4 Measurement ID (optional, analytics disabled if empty)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Environment
NODE_ENV=production
