{
  "name": "iica-plataforma",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:seed": "tsx prisma/seed.ts",
    "db:setup": "npm run prisma:generate && npm run prisma:push && npm run prisma:seed",
    "scrape": "tsx lib/scrapers.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.0",
    "@prisma/client": "^5.10.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.2",
    "@tailwindcss/line-clamp": "^0.4.4",
    "autoprefixer": "^10.4.0",
    "axios": "^1.7.0",
    "cheerio": "^1.0.0-rc.12",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "es-abstract": "^1.24.2",
    "framer-motion": "^12.26.2",
    "lucide-react": "^0.441.0",
    "next": "^14.2.23",
    "next-intl": "^3.9.0",
    "next-pwa": "^5.6.0",
    "next-themes": "^0.3.0",
    "postcss": "^8.4.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "string.prototype.matchall": "^4.0.12",
    "string.prototype.trim": "^1.2.10",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.7.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^14.2.0",
    "@types/jest": "^29.5.12",
    "@types/node": "^25.0.3",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "prisma": "^5.10.0",
    "typescript": "^5.9.3"
  },
  "description": "Plataforma web para visualizar y buscar oportunidades de financiamiento agrícola de FAO, BID y FONTAGRO.",
  "main": "next.config.js",
  "directories": {
    "lib": "lib",
    "test": "tests"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/maximilianoandrade-sys/iica-chile-plataforma.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/maximilianoandrade-sys/iica-chile-plataforma/issues"
  },
  "homepage": "https://github.com/maximilianoandrade-sys/iica-chile-plataforma#readme",
  "jest": {
    "preset": "next/jest",
    "testEnvironment": "jest-environment-jsdom",
    "setupFilesAfterEnv": [
      "<rootDir>/tests/setup.ts"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1"
    },
    "testPathIgnorePatterns": [
      "<rootDir>/node_modules/",
      "<rootDir>/.next/"
    ],
    "collectCoverageFrom": [
      "components/**/*.tsx",
      "lib/**/*.ts",
      "app/**/*.tsx",
      "!**/*.d.ts"
    ]
  }
}
